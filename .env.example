# ── Шаблон конфигурации FullSell ──
# Скопируй в .env, поменяй значения, потом docker compose up -d

# Домен (без https:// и без слеша). Должен указывать на этот сервер по DNS.
DOMAIN=fullsell.example.com

# Пароли — сгенерируй любые длинные строки (минимум 16 символов)
POSTGRES_PASSWORD=change_me_to_random_secret
DASHBOARD_PASSWORD=Fullsell2026
SECRET_KEY=change_me_to_random_secret_32_chars_min
CONNECTOR_SECRET=Fullsell2026

# Ключ Anthropic из console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...
